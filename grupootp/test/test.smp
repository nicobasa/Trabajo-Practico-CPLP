program miprograma {

    println "\r=== Declaracion de tipos de datos ===";
    var entero = 3;
    var decimal = 2.5;
    var texto = "hola";
    var bandera = true;

    println entero;
    println decimal;
    println texto;
    println bandera;

    println "\r=== Expresiones aritmeticas ===";
    println entero + 2 * 4;
    println (entero + 2) * 4;
    println decimal + 1.499;
    println 10 - 4;
    println 20 / 2;

    println "\r=== Strings ===";
    println texto + " mundo";
    println "El valor de entero es: " + entero;
    println "El valor de decimal es: " + decimal;

    println "\r=== Expresiones relacionales ===";
    println entero > 2;
    println entero < 2;
    println entero >= 3;
    println entero <= 3;
    println entero == 3;
    println entero != 4;

    println "\r=== Expresiones logicas ===";
    println bandera && true;
    println bandera || false;
    println !false;
    println entero >= 3 && bandera;
    println entero < 3 || bandera;

    println "\r=== Asignaciones ===";
    entero = entero + 7;
    decimal = decimal + 0.5;
    texto = texto + " actualizado";
    bandera = false;

    println entero;
    println decimal;
    println texto;
    println bandera;

    println "\r=== If true ===";
    if (entero >= 10) {
        println "entro al if";
    } else {
        println "entro al else";
    }

    println "\r=== If false ===";
    if (entero < 5) {
        println "entro al if";
    } else {
        println "entro al else";
    }

    /*
       Comentario multilínea:
       Esta parte no deberia ejecutarse.
       println 999;
    */

    println "\r=== For con variable de control ===";
    for (var i = 0; i < 5; i = i + 1) {
        println i;
    }

    println "\r=== For con real ===";
    for (var r = 0.5; r < 2.0; r = r + 0.25) {
        println r;
    }

    println "\r";
}

